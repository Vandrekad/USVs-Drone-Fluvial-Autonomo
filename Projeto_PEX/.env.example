# Firebase Vite environment variables for Projeto_PEX
# Copy this file to `.env` and fill the values from your Firebase project settings.
# Restart the dev server after editing the .env file.

# Required values (must be set for the app to connect to Firebase Realtime Database and Auth)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=1:xxxxxxxxxxxx:web:xxxxxxxxxxxxxxxx

# Notes:
# - `VITE_FIREBASE_DATABASE_URL` must point to your Realtime Database endpoint
#   (examples: https://<project>.firebaseio.com or https://<project>.<region>.firebasedatabase.app)
# - Make sure Email/Password provider is enabled in Firebase Authentication if you plan
#   to use the email login flow with `signInWithEmailAndPassword`.
# - The app checks these env vars at runtime; if any required key is missing the project
#   will run in mock mode (no real Firebase connection).

# Optional: local development with a demo user
# You can add a test operator account in Firebase Auth with email `operador@usv-am.local`
# and a password you control for convenient testing.

